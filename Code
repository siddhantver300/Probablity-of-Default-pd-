#####PD Model##############
#train test split
set.seed(123)

train_index <- createDataPartition(clean_data$loan_status, p = 0.7, list = FALSE)

train_data <- clean_data[train_index, ]
test_data  <- clean_data[-train_index, ]

##Regression Model
pd_model <- glm(loan_status ~ person_income + person_emp_length +
                  loan_amnt + loan_int_rate + loan_percent_income +
                  cb_person_cred_hist_length +
                  person_home_ownership + loan_intent + loan_grade,
                
                data = train_data,
                family = binomial)
summary(pd_model)

#predict probablity
test_data$pd_prob <- predict(pd_model, newdata = test_data, type = "response")
test_data$pd_pred <- ifelse(test_data$pd_prob > 0.3, 1, 0)
confusionMatrix(as.factor(test_data$pd_pred), as.factor(test_data$loan_status))



roc_obj <- roc(test_data$loan_status, test_data$pd_prob)

plot(roc_obj, col = "blue", main = "ROC Curve")

auc(roc_obj)
